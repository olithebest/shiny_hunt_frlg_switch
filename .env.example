# Shiny Hunter FRLG — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# Resend API key — free email delivery via HTTPS (no SMTP, works on Render)
# Sign up at https://resend.com, go to API Keys, create a key.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# The From address shown to buyers.
# Use onboarding@resend.dev for testing (free, no domain needed).
# Once you verify a domain at resend.com, change to: Shiny Hunter <you@yourdomain.com>
FROM_EMAIL=onboarding@resend.dev

# Master signing secret for license keys.
# Change this to any long random string before going live.
# All keys will be signed with this — keep it secret, never share it.
SHINY_HUNTER_SECRET=change-me-before-shipping-use-a-long-random-string-here

# Optional: itch.io webhook secret (for verifying requests come from itch.io)
# Leave blank if you don't set one in itch.io dashboard.
ITCH_WEBHOOK_SECRET=
