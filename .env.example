# Shiny Hunter FRLG — Environment Variables

# SendGrid API key — free 100 emails/day, no domain needed
# Sign up at https://sendgrid.com → Settings → API Keys → Create API Key (Full Access)
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx

# Your verified sender email (Single Sender Verification in SendGrid)
# SendGrid → Settings → Sender Authentication → Single Sender Verification → verify your email
FROM_EMAIL=your_email@example.com

# Master signing secret for license keys.
SHINY_HUNTER_SECRET=change-me-before-shipping-use-a-long-random-string-here

# Optional: itch.io webhook secret
ITCH_WEBHOOK_SECRET=
