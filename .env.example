# Shiny Hunter FRLG — Environment Variables

# Mailjet API keys — free 200 emails/day, no domain needed
# Sign up at https://app.mailjet.com → Account Settings → API Keys
MAILJET_API_KEY=your_mailjet_api_key
MAILJET_SECRET_KEY=your_mailjet_secret_key

# Your verified sender email
# Mailjet → Account Settings → Sender domains & addresses → Add a sender address
FROM_EMAIL=your_email@example.com

# Master signing secret for license keys.
SHINY_HUNTER_SECRET=change-me-before-shipping-use-a-long-random-string-here

# Optional: itch.io webhook secret
ITCH_WEBHOOK_SECRET=
