# Shiny Hunter FRLG — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# Brevo (formerly Sendinblue) API key — free email delivery via HTTPS
# Sign up at https://brevo.com, go to Settings → API Keys → Create a key
BREVO_API_KEY=xkeysib-xxxxxxxxxxxx

# The From address shown to buyers.
# Must be verified as a sender in Brevo: Settings → Senders & IPs → Add a sender
FROM_EMAIL=your_email@example.com

# Master signing secret for license keys.
SHINY_HUNTER_SECRET=change-me-before-shipping-use-a-long-random-string-here

# Optional: itch.io webhook secret
ITCH_WEBHOOK_SECRET=
